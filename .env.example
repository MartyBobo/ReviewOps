# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5080

# Database
ConnectionStrings__ReviewOpsDb=Host=localhost;Port=5432;Database=reviewops;Username=reviewops;Password=reviewops

# Demo auth
Auth__DemoMode=true
Auth__DemoUserId=11111111-1111-1111-1111-111111111111
Auth__DemoUserEmail=owner@example.com

# Worker scheduling
Worker__EnableScheduledJobs=true
Worker__ReviewSyncIntervalMinutes=60
Worker__AnalysisIntervalMinutes=5
Worker__AlertEvaluationIntervalMinutes=10

# AI analysis
Ai__Provider=RuleBased
OpenAi__ApiKey=
OpenAi__Model=

# Email
Email__Provider=Console
Email__From=alerts@reviewops.local
Resend__ApiKey=

# Google Business Profile optional adapter
Google__EnableProvider=false
Google__EnableReplyPosting=false
Google__AccessToken=
Google__AccountId=
Google__LocationId=

# Frontend
VITE_API_BASE_URL=http://localhost:5080
